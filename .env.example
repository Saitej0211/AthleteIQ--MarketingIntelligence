# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Instagram credentials (throwaway account) — primary scraper, unlimited & free
# Create any Instagram account → add credentials here
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# RapidAPI — fallback Instagram scraping (used if IG credentials not set)
# Sign up free at https://rapidapi.com → "Instagram API – Fast & Reliable Data"
RAPIDAPI_KEY=your_rapidapi_key_here

# LLM (choose one or both)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Scraping settings
REQUEST_DELAY_SECONDS=2
MAX_RETRIES=3
